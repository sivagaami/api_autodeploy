pipeline {
    agent any
environment {
        PATH = "/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin"
    }
    
    stages {

        stage('Checkout') {
            steps {
                echo 'Code cloned from GitHub'
            }
        }
        stage('Git Check') {
            steps {
                sh 'git --version'
            }
        }

        stage('Docker Check') {
            steps {

                    sh 'echo $PATH'
                    sh 'whoami'
                    sh 'which docker'
                    sh '$(which docker) --version'

                     }
                }
        

        stage('Build') {
            steps {
                echo 'Building application'
            }
        }

        stage('Test') {
            steps {
                echo 'Running tests'
            }
        }

    }
}